#!/bin/sh
# StickShift pre-commit hook -- runs the stack guard before a commit is allowed,
# so encoding problems are caught here instead of in CI.
#
# Enable once per clone:
#     git config core.hooksPath .githooks
#
# This hook is version-controlled (unlike .git/hooks/), so everyone who runs the
# command above gets the same check. It calls the SAME script CI runs, so local
# and CI never drift.

if command -v python3 >/dev/null 2>&1; then
  PY=python3
else
  PY=python
fi

"$PY" scripts/check_ascii.py
status=$?

if [ "$status" -ne 0 ]; then
  echo
  echo "Commit blocked by the stack guard. Fix the items above, then commit again."
  echo "(To bypass in an emergency: git commit --no-verify -- but CI will still reject.)"
  exit 1
fi

exit 0
